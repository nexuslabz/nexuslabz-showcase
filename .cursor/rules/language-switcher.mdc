## 2. Static HTML Pages (Vanilla JS)

For pages that are NOT Vue apps (e.g. `public/index.html`, root `index.html`).

### HTML Structure

```html
<div class="lang-dd" id="langDD">
  <button class="lang-dd__trigger" id="langTrigger">
    <svg class="lang-dd__flag" id="flagCurrent" viewBox="0 0 640 480"></svg>
    <span class="lang-dd__label" id="langLabel">EN</span>
    <svg class="lang-dd__chevron" width="12" height="12" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </button>
  <div class="lang-dd__menu" id="langMenu">
    <button class="lang-dd__option lang-dd__option--active" data-lang="en">
      <svg class="lang-dd__flag" id="flagEN" viewBox="0 0 640 480"></svg>
      <span class="lang-dd__option-label">EN</span>
      <svg class="lang-dd__check" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="3">
        <path d="M5 12l5 5L20 7" />
      </svg>
    </button>
    <button class="lang-dd__option" data-lang="pt">
      <svg class="lang-dd__flag" id="flagBR" viewBox="0 0 640 480"></svg>
      <span class="lang-dd__option-label">BR</span>
    </button>
  </div>
</div>
```

### Translatable Content

Use `data-en` and `data-pt` attributes on any element that needs translation:

```html
<h2 data-en="Our Values" data-pt="Nossos Valores">Our Values</h2>
<p data-en="We build products." data-pt="Construímos produtos.">We build products.</p>
```

The JS swaps `innerHTML` based on selected locale.

### JavaScript Pattern

```javascript
(function () {
  var US_FLAG = '...'; // Full US SVG innerHTML
  var BR_FLAG = '...'; // Full BR SVG innerHTML
  var CHECK_SVG = '<svg class="lang-dd__check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12l5 5L20 7"/></svg>';

  var dd = document.getElementById('langDD');
  var trigger = document.getElementById('langTrigger');
  var flagCurrent = document.getElementById('flagCurrent');
  var langLabel = document.getElementById('langLabel');
  var options = document.querySelectorAll('.lang-dd__option');

  document.getElementById('flagEN').innerHTML = US_FLAG;
  document.getElementById('flagBR').innerHTML = BR_FLAG;

  var locale = localStorage.getItem('nexus-locale') || 'en';

  function setLocale(lang) {
    locale = lang;
    localStorage.setItem('nexus-locale', lang);
    flagCurrent.innerHTML = lang === 'en' ? US_FLAG : BR_FLAG;
    langLabel.textContent = lang === 'en' ? 'EN' : 'BR';

    // Toggle active state and checkmark
    options.forEach(function (o) {
      var isActive = o.dataset.lang === lang;
      o.classList.toggle('lang-dd__option--active', isActive);
      var existing = o.querySelector('.lang-dd__check');
      if (isActive && !existing) o.insertAdjacentHTML('beforeend', CHECK_SVG);
      else if (!isActive && existing) existing.remove();
    });

    // Swap all translatable content
    document.querySelectorAll('[data-en]').forEach(function (el) {
      el.innerHTML = lang === 'en' ? el.dataset.en : el.dataset.pt;
    });

    document.documentElement.lang = lang === 'en' ? 'en' : 'pt-BR';
    dd.classList.remove('lang-dd--open');
  }

  trigger.addEventListener('click', function () {
    dd.classList.toggle('lang-dd--open');
  });

  document.addEventListener('pointerdown', function (e) {
    if (!dd.contains(e.target)) dd.classList.remove('lang-dd--open');
  });

  options.forEach(function (o) {
    o.addEventListener('click', function () { setLocale(o.dataset.lang); });
  });

  setLocale(locale);
})();
```

### Required CSS for Static Pages

Copy the exact same CSS classes from the Vue component. Key differences:
- In Vue presentations: `.lang-dd` uses `position: fixed; top: 1rem; right: 1rem;`
- In static pages embedded in navbars: `.lang-dd` uses `position: relative;`
- The dropdown menu in static pages needs explicit opacity/transform transition since there is no Vue `<Transition>`:

```css
.lang-dd__menu {
  opacity: 0;
  transform: translateY(-4px) scale(0.97);
  pointer-events: none;
  transition: opacity 0.15s ease-out, transform 0.15s ease-out;
}
.lang-dd--open .lang-dd__menu {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: auto;
}
```

